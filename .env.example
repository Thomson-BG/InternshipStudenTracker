# Environment Variables Template
# Copy this file to .env.local or .env.production and fill in the actual values
# IMPORTANT: Never commit actual credentials to version control

# Backend API base URL override (frontend)
# Optional. Defaults to /api/exec.
VITE_API_BASE_URL=/api/exec

# Neon Postgres connection string (backend + migration scripts)
DATABASE_URL=postgresql://username:password@host/database?sslmode=require&channel_binding=require

# Optional fallback env name for DATABASE_URL
NEON_DATABASE_URL=

# Admin auth settings for backend
# Preferred: use ADMIN_PASSWORD_HASH (sha256 hex)
ADMIN_PASSWORD_HASH=
# Optional plain-text value (backend will hash it on startup)
ADMIN_PASSWORD=

# Admin password for test environment
# Only used when running Playwright tests
PLAYWRIGHT_ADMIN_PASSWORD=your_test_password_here
