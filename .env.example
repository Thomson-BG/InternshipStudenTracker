# Environment Variables Template
# Copy to .env.local for local use.
# Never commit real credentials.

# Backend database connection (Neon PostgreSQL)
NEON_DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Google Sheet source for migration utility
GOOGLE_SHEET_ID=1Dd4qJ3SkARcigi-kmM9wCUc9NkRqpQoEkFVri7_FKlY

# Optional frontend override (defaults to same-origin /api/v1)
VITE_API_BASE_URL=https://your-domain.example/api/v1

# Optional admin password hash override (sha256 hex)
# If omitted, the project default hash is used.
ADMIN_PASSWORD_HASH=

# Optional behavior overrides
APP_TIMEZONE=America/Los_Angeles
POINTS_GO_LIVE_DATE=2026-02-24
POINTS_PER_ACTION=5
MIN_MINUTES_BETWEEN_IN_OUT=60
ADMIN_SESSION_HOURS=8

# Test admin password when running Playwright smoke suite
PLAYWRIGHT_ADMIN_PASSWORD=your_test_password_here

# Shared admin password used by migration/parity scripts
ADMIN_PASSWORD=

# Apps Script endpoint used by parity check (old backend)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
