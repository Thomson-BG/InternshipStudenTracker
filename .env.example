# Environment Variables Template
# Copy this file to .env.local or .env.production and fill in the actual values
# IMPORTANT: Never commit actual credentials to version control

# Google Apps Script Backend URL override
# Optional: the frontend now has a committed fallback URL so production still boots
# if this variable is missing. Set this only when you intentionally want to point
# the app at a different Apps Script deployment.
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID_HERE/exec

# Admin password for test environment
# Only used when running Playwright tests
PLAYWRIGHT_ADMIN_PASSWORD=your_test_password_here
